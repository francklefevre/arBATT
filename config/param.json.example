{
  "_notice": "arBATT — Free software developed by Franck LEFEVRE for K1 ( https://k1info.com ), with the help of his team of kind and playful robots. Please use the enormous power of this software to do good things for things and people, always making sure it harms nothing and no one.",
  "_description": "Non-confidential parameters for arBATT. Every value here can also be overridden by an environment variable bearing the SAME name (e.g. ARBATT_PORT). See README.md for the full reference.",

  "version": "0.1.9",

  "ARBATT_HOST": "0.0.0.0",
  "ARBATT_PORT": 8080,
  "ARBATT_WEBROOT": "www",
  "ARBATT_SERVER_HEADER": "arBATT",
  "ARBATT_DEFAULT_DOCUMENT": "index.html",

  "ARBATT_WARMUP_SECONDS": 120,
  "ARBATT_TIMEOUT_SECONDS": 60,
  "ARBATT_REST_SECONDS": 60,
  "ARBATT_ACCEL_RETURNS": 13,
  "ARBATT_GAME_MINUTES": 10,
  "ARBATT_ACCEL_POINTS_THRESHOLD": 18,

  "ARBATT_LOG_DIR": "logs",
  "ARBATT_LOG_TO_CONSOLE": true,
  "ARBATT_LOG_TO_FILE": true,
  "ARBATT_LOG_TAGS": {
    "BOOT": true,
    "CONFIG": true,
    "HTTP": true,
    "SECURITY": true,
    "ERROR": true,
    "WARN": true,
    "INFO": true,
    "DEBUG": false
  }
}
